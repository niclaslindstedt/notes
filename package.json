{
  "name": "notes",
  "version": "1.4.0",
  "description": "A local-first PWA for taking notes that works great on mobile and desktop.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:seed": "vite --mode seed",
    "build": "vite build",
    "build:seed": "vite build --mode seed",
    "build:native": "VITE_TARGET=native vite build --outDir native/web --emptyOutDir",
    "preview": "vite preview",
    "preview:seed": "npm run build:seed && vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "icons": "pwa-assets-generator"
  },
  "author": "Niclas Lindstedt <niclas@agilator.se>",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/opendyslexic": "^5.2.5",
    "@fontsource/source-serif-4": "^5.3.0",
    "@niclaslindstedt/oss-framework": "^2.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "eslint-plugin-import": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  }
}
