# Dependency lockfile — generated on install; this Expo project pins exact
# versions in package.json and has never tracked a lockfile.
package-lock.json

# Expo / native build artifacts
.expo/
dist/
web-build/
ios/
android/

# The embedded web bundle, produced by `make build-native` (relative-base,
# service-worker-free copy of the web app) and copied into the binary at
# prebuild. Generated, never tracked.
web/

# Secrets — never commit store credentials
play-service-account.json
*.p8
*.p12
*.keystore
