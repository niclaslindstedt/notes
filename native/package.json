{
  "name": "notes-native",
  "version": "0.1.0",
  "private": true,
  "description": "React Native (Expo) front-end for the notes app. Shares the platform-agnostic core (domain, storage interface, app hooks) with the web PWA under ../src.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "expo": "~53.0.0",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-icloudstore": "0.9.0",
    "react-native-safe-area-context": "5.4.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
