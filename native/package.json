{
  "name": "notes-native",
  "version": "0.1.0",
  "private": true,
  "description": "Thin React Native (Expo) WebView wrapper around the notes web PWA. Embeds the compiled web app (built into ./web) and adds only native haptics and SPKI-pinned HTTPS for the self-hosted notesd backend.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~53.0.0",
    "expo-camera": "~16.1.5",
    "expo-file-system": "~18.1.10",
    "expo-haptics": "~14.1.4",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-safe-area-context": "5.4.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
