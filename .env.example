# Build-time configuration for the cloud storage backends. Copy to
# `.env.local` for local dev, or set these as CI secrets for the production
# build. Each is OPTIONAL: unset, the matching backend is simply hidden from
# the storage picker (This device, Local folder, and encryption need nothing).

# Dropbox app key — register a "Scoped access" app with permission type
# "App folder" at https://www.dropbox.com/developers/apps and add this origin
# (no trailing slash) to its redirect URIs.
VITE_DROPBOX_APP_KEY=

# Dropbox app folder name — must match the "App folder" on the registration
# above (Dropbox creates `Apps/<this>/`). Unset defaults to `free-notes`.
VITE_DROPBOX_APP_FOLDER=

# Google OAuth client id — create an OAuth client in a Google Cloud project
# with the Drive API enabled, and add this origin to its authorized origins.
VITE_GOOGLE_CLIENT_ID=

# Optional donate link surfaced in the side menu (unrelated to storage).
VITE_DONATE_URL=
